# Canvas API Access Token
# Get yours from: Canvas → Account → Settings → New Access Token
CANVAS_TOKEN=your_canvas_access_token_here

# Canvas API Base URL (ASU Canvas)
CANVAS_BASE_URL=https://canvas.asu.edu

# Anthropic API Key (for AI-powered summaries)
# Get yours from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here
